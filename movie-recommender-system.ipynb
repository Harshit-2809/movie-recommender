  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Merge the two dataframes\n",
    "movies_df = movies_df.merge(credits_df, left_on='id', right_on='movie_id')\n",
    "print(\"Merged Dataset Shape:\", movies_df.shape)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Function to convert string representation of list to actual list\n",
    "def convert_to_list(obj):\n",
    "    if pd.isna(obj):\n",
    "        return []\n",
    "    if isinstance(obj, str):\n",
    "        try:\n",
    "            return ast.literal_eval(obj)\n",
    "        except:\n",
    "            return []\n",
    "    return obj\n",
    "\n",
    "# Convert columns from string to list\n",
    "movies_df['genres'] = movies_df['genres'].apply(convert_to_list)\n",
    "movies_df['keywords'] = movies_df['keywords'].apply(convert_to_list)\n",
    "movies_df['cast'] = movies_df['cast'].apply(convert_to_list)\n",
    "movies_df['crew'] = movies_df['crew'].apply(convert_to_list)\n",
    "\n",
    "print(\"Genres (first movie):\", movies_df['genres'].iloc[0][:3])"
   ]
  },
